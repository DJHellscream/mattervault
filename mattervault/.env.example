# ==============================================================================
# MATTERVAULT .ENV TEMPLATE
# ------------------------------------------------------------------------------
# Copy this file to .env and customize ALL values before first run.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to Git. It contains secrets.
# ==============================================================================

# ==============================================================================
# PAPERLESS-NGX (Document Vault)
# ==============================================================================

# Database password for Paperless PostgreSQL
PAPERLESS_DB_PASS=CHANGE_ME_paperless_db_password

# Django secret key — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
PAPERLESS_SECRET=CHANGE_ME_generate_a_random_secret_key

# Admin login credentials for Paperless web UI (http://localhost:8000)
PAPERLESS_ADMIN_PASS=CHANGE_ME_admin_password
PAPERLESS_USER=admin
PAPERLESS_PASS=${PAPERLESS_ADMIN_PASS}  # Same as admin password

# ==============================================================================
# N8N (Workflow Orchestration)
# ==============================================================================

# Database password for n8n PostgreSQL
N8N_DB_PASS=CHANGE_ME_n8n_db_password

# Basic auth password for n8n web UI (http://localhost:5678)
N8N_AUTH_PASS=CHANGE_ME_n8n_ui_password

# n8n API key — generate one from n8n UI: Settings → API → Create API Key
# Leave blank on first run, then generate and paste here after setup
N8N_API_KEY=

# ==============================================================================
# CHAT UI
# ==============================================================================

# Ollama model for chat responses (must be pulled on host: ollama pull qwen3:8b)
OLLAMA_CHAT_MODEL=qwen3:8b

# Number of previous messages to include for conversation context (sliding window)
# Set to 0 to disable conversation memory
CHAT_HISTORY_LIMIT=10

# Database password for Chat UI PostgreSQL
CHATUI_DB_PASS=CHANGE_ME_chatui_db_password

# JWT secret for authentication — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_jwt_secret

# ==============================================================================
# ALERTING (Optional)
# ==============================================================================

# n8n webhook URL for system alerts (dashboard → n8n → email)
# This is the internal Docker URL — no need to change unless you rename containers
ALERT_WEBHOOK_URL=http://matterlogic:5678/webhook/system-alert

# Email recipients — configure SMTP credentials in n8n UI (Settings → Credentials)
# Then set these in n8n environment or the System Alerts workflow
# ALERT_TO_EMAIL=admin@yourfirm.com
# ALERT_FROM_EMAIL=mattervault@yourfirm.com

# ==============================================================================
# SERVICE URLS & MODELS (used by n8n workflows + dashboard)
# ==============================================================================

# Base path for all volume mounts in docker-compose.yml
# On Windows, set to your full project path (e.g., D:\CCC\mattervault)
# On Mac/Linux, use "." for current directory (default)
MATTERVAULT_DATA_DIR=.

# --- AI Models ---

# Reranker model (used by n8n chat workflow for result scoring)
OLLAMA_RERANKER_MODEL=qwen3:8b

# Embedding model (used by n8n ingestion + chat workflows)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Service URLs (internal Docker network) ---

# Ollama API (native host — accessed via Docker host gateway)
OLLAMA_URL=http://host.docker.internal:11434

# Docling API (native host — accessed via Docker host gateway)
DOCLING_URL=http://host.docker.internal:5001

# Qdrant vector database (Docker container on matternet)
QDRANT_URL=http://mattermemory:6333

# Qdrant collection name (must match init-mattervault.sh)
QDRANT_COLLECTION=mattervault_documents_v2

# Paperless-ngx internal URL (Docker container on matternet)
PAPERLESS_INTERNAL_URL=http://mattervault:8000

# n8n internal URL (Docker container on matternet)
N8N_INTERNAL_URL=http://matterlogic:5678

# ==============================================================================
# QUICK START
# ==============================================================================
#
# 1. Copy this file:          cp .env.example .env
# 2. Edit ALL "CHANGE_ME" values in .env
# 3. Start native services:   (on host machine)
#      Windows:  $env:OLLAMA_HOST="0.0.0.0"; ollama serve
#      Mac/Linux: OLLAMA_HOST=0.0.0.0 ollama serve
#      Docling:  docling-serve --host 0.0.0.0 --port 5001 --no-ui
# 4. Pull the LLM model:      ollama pull qwen3:8b
# 5. Pull the embedding model: ollama pull nomic-embed-text
# 6. Start Docker:             docker compose up -d
# 7. Run init script:          ./scripts/init-mattervault.sh
# 8. Create intake folders:    mkdir -p ./intake/smith ./intake/jones
# 9. Access:
#      Chat UI:    http://localhost:3007
#      Paperless:  http://localhost:8000
#      n8n:        http://localhost:5678
#      Dashboard:  http://localhost:3006
#      Qdrant:     http://localhost:6333/dashboard
#
# ==============================================================================
